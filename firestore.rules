rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUid() {
      return request.auth.uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(currentUid()));
    }

    function userOrgId() {
      return userDoc().data.orgId;
    }

    function hasOrgAccess(orgId) {
      return isSignedIn() && userOrgId() == orgId;
    }

    function hasAdminRights() {
      return isSignedIn() &&
          (userDoc().data.role == 'director' ||
              userDoc().data.role == 'masterOwner');
    }

    function userRole() {
      return userDoc().data.role;
    }

    function orgDoc(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId));
    }

    function orgPlan(orgId) {
      return orgDoc(orgId).data.plan;
    }

    function orgPlanStatus(orgId) {
      return orgDoc(orgId).data.planStatus;
    }

    function planStatusGrantsAccess(status) {
      return status in ['active', 'trial', 'grace'];
    }

    function orgHasProAccess(orgId) {
      return orgPlan(orgId) in ['pro', 'business'] &&
          planStatusGrantsAccess(orgPlanStatus(orgId));
    }

    function orgHasBusinessAccess(orgId) {
      return orgPlan(orgId) == 'business' &&
          planStatusGrantsAccess(orgPlanStatus(orgId));
    }

    function callerOrgId() {
      return userDoc().data.orgId;
    }

    function callerHasProAccess() {
      let orgId = callerOrgId();
      return orgId is string && orgId.size() > 0 && orgHasProAccess(orgId);
    }

    function touchesBookingSchedule() {
      return request.resource.data.diff(resource.data)
          .affectedKeys().hasAny(['bookingSchedule']);
    }

    function clientCount(orgId) {
      let count = orgDoc(orgId).data.clientCount;
      return count is int ? count : 0;
    }

    // Returns true if the org is on a paid plan or within the free client limit.
    function withinClientLimit(orgId) {
      return orgPlan(orgId) in ['pro', 'business'] ||
          clientCount(orgId) < 20;
    }

    function currentMonthKey() {
      return string(request.time.year()) + '-' + string(request.time.month());
    }

    function activeOrdersThisMonth(orgId) {
      let data = orgDoc(orgId).data;
      let storedKey = data.activeOrdersMonthKey;
      let count = data.activeOrdersThisMonthCount;
      return storedKey is string && storedKey == currentMonthKey()
          ? (count is int ? count : 0)
          : 0;
    }

    function orderIsActive(data) {
      let status = data.status;
      return status != 'completed' && status != 'paid';
    }

    function orderBecomingActive() {
      return !orderIsActive(resource.data) && orderIsActive(request.resource.data);
    }

    // Free plan: max 10 non-completed/non-paid orders in the current calendar month.
    function withinOrderLimit(orgId) {
      return orgPlan(orgId) in ['pro', 'business'] ||
          activeOrdersThisMonth(orgId) < 10;
    }

    function canWriteOrderData(data) {
      return data.assignedToUid == null ||
          data.assignedToUid == '' ||
          data.assignedToUid == currentUid();
    }

    function canMasterCreateOrder() {
      return userRole() == 'master' && canWriteOrderData(request.resource.data);
    }

    function canMasterUpdateOrder() {
      return userRole() == 'master' &&
          canWriteOrderData(resource.data) &&
          canWriteOrderData(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
          currentUid() == userId ||
          (hasAdminRights() && resource.data.orgId == userOrgId())
      );
      // Block creating user profile with sensitive access/billing fields.
      allow create: if isSignedIn() && currentUid() == userId
          && !request.resource.data.keys().hasAny([
            'role',
            'orgId',
            'plan',
            'planStatus',
            'billingProvider',
          ]);
      // Prevent self-escalation and client-side billing tampering.
      // Access/billing fields are managed by secure backend flows.
      allow update: if isSignedIn() && currentUid() == userId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'role',
            'orgId',
            'plan',
            'planStatus',
            'billingProvider',
          ])
          && (!touchesBookingSchedule() || callerHasProAccess());
      allow delete: if false;
    }

    match /public_users/{userId} {
      // Public profiles are visible only for own doc or same-organization users.
      allow get, list: if isSignedIn() && (
          currentUid() == userId ||
          resource.data.orgId == userOrgId()
      );
      allow create, update: if isSignedIn() && currentUid() == userId;
      allow delete: if false;
    }

    match /organizations/{orgId} {
      allow read: if hasOrgAccess(orgId);
      // Billing fields are managed only by backend/Admin SDK.
      allow create: if isSignedIn()
          && request.resource.data.ownerId == currentUid()
          && !request.resource.data.keys().hasAny([
            'plan',
            'planStatus',
            'billingProvider',
            'seatLimit',
            'clientCount',
            'clientCountUpdatedAt',
            'activeOrdersThisMonthCount',
            'activeOrdersMonthKey',
            'activeOrdersQuotaUpdatedAt',
            'quotasInitializedAt',
          ]);
      allow update: if hasOrgAccess(orgId)
          && hasAdminRights()
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'plan',
            'planStatus',
            'billingProvider',
            'seatLimit',
            'clientCount',
            'clientCountUpdatedAt',
            'activeOrdersThisMonthCount',
            'activeOrdersMonthKey',
            'activeOrdersQuotaUpdatedAt',
            'quotasInitializedAt',
          ]);
      allow delete: if false;
    }

    // ── Orders ──────────────────────────────────────────────────────
    // All org members can READ, CREATE and UPDATE.
    // Only directors / owners may DELETE.
    match /organizations/{orgId}/orders/{orderId} {
      allow read: if hasOrgAccess(orgId);
      allow create: if hasOrgAccess(orgId)
          && (hasAdminRights() || canMasterCreateOrder())
          && (!orderIsActive(request.resource.data) || withinOrderLimit(orgId));
      allow delete: if hasOrgAccess(orgId) && hasAdminRights();
      allow update: if hasOrgAccess(orgId)
          && (hasAdminRights() || canMasterUpdateOrder())
          && (!orderBecomingActive() || withinOrderLimit(orgId));
    }

    // ── Clients ─────────────────────────────────────────────────────
    // All org members can READ, CREATE and UPDATE clients.
    // Only admins may DELETE clients.
    match /organizations/{orgId}/clients/{clientId} {
      allow read: if hasOrgAccess(orgId);
      allow create: if hasOrgAccess(orgId) && withinClientLimit(orgId);
      allow update: if hasOrgAccess(orgId);
      allow delete: if hasOrgAccess(orgId) && hasAdminRights();
    }

    // ── Inventory ───────────────────────────────────────────────────
    // All org members can READ inventory.
    // Admins can do full CRUD; masters can also UPDATE (restock / status).
    match /organizations/{orgId}/inventory/{itemId} {
      allow read: if hasOrgAccess(orgId);
      allow create, delete: if hasOrgAccess(orgId) && hasAdminRights();
      allow update: if hasOrgAccess(orgId) && (hasAdminRights() || userRole() == 'master');
    }

    match /organizations/{orgId}/services/{serviceId} {
      // Allow public read so the booking page can show the studio's price list.
      allow read: if true;
      allow create, update, delete: if hasOrgAccess(orgId) && hasAdminRights();
    }

    match /organizations/{orgId}/chat_rooms/{roomId} {
      // Internal organization room: all organization members can participate.
      allow read, create, update: if hasOrgAccess(orgId);
      allow delete: if hasOrgAccess(orgId) && hasAdminRights();

      match /messages/{messageId} {
        allow read, create: if hasOrgAccess(orgId);
        allow update, delete: if false;
      }
    }

    match /organizations/{orgId}/{collection}/{docId} {
      allow read: if hasOrgAccess(orgId);
      allow create, update, delete: if hasOrgAccess(orgId) && hasAdminRights();
    }

    match /chat_rooms/{roomId} {
      // read/update: user must already be a participant
      allow read, update: if isSignedIn() &&
          request.auth.uid in resource.data.participantIds;
      // create: creator must include themselves as participant
      allow create: if isSignedIn() &&
          request.auth.uid in request.resource.data.participantIds;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() &&
            request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.participantIds;
        allow create: if isSignedIn() &&
            request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.participantIds;
        allow update, delete: if false;
      }
    }

    // ── Public online booking requests ─────────────────────────────
    // Clients can submit requests without authentication.
    // Only the target specialist (masterUid) can read and update status.
    match /booking_requests/{requestId} {
      // Create is performed only by backend Cloud Function (Admin SDK).
      allow create: if false;

      allow read: if isSignedIn()
          && resource.data.masterUid == currentUid()
          && callerHasProAccess();

      // State machine: client can only transition pending → accepted or pending → declined.
      // All import-related fields (importedToApp, importedAt, importedOrderId, importedClientId)
      // are now written exclusively by the backend Cloud Function via Admin SDK.
      allow update: if isSignedIn()
          && resource.data.masterUid == currentUid()
          && callerHasProAccess()
          && resource.data.status == 'pending'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'updatedAt',
          ])
          && request.resource.data.status in ['accepted', 'declined'];

      allow delete: if false;
    }

    // ── App config (force-update version gates) ───────────────────────
    // Publicly readable so the client can check before authentication.
    match /app_config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Invite codes ─────────────────────────────────────────────────
    // Access is limited to admins within their own organization.
    match /invites/{code} {
      allow get, list: if hasAdminRights() && resource.data.orgId == userOrgId();
      allow create: if hasAdminRights()
          && request.resource.data.orgId == userOrgId()
          && request.resource.data.directorUid == currentUid();
      allow update: if false;
      allow delete: if false;
    }

    // ── Invite rate-limiting counters ─────────────────────────────────
    // Each user can only write to their own attempt counter doc.
    match /invite_attempts/{uid} {
      allow read, write: if isSignedIn() && currentUid() == uid;
    }
  }
}
