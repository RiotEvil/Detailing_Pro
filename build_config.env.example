# Build configuration — copy to build_config.env and fill in real values.
# build_config.env is gitignored and must NOT be committed.
#
# Usage:
#   flutter build appbundle --release --dart-define-from-file=build_config.env
#
# RevenueCat Public SDK Keys (not secret — safe to store in CI secrets).
# Get them from: RevenueCat Dashboard → Project → API Keys → Public (SDK)
RC_ANDROID_API_KEY=appl_REPLACE_WITH_YOUR_ANDROID_PUBLIC_SDK_KEY

# Optional: override offering IDs (defaults to "pro" / "business")
# RC_PRO_OFFERING_ID=pro
# RC_BUSINESS_OFFERING_ID=business
